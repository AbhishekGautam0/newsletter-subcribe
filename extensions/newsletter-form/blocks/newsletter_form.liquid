<div class="newsletter-form-block" style="background:#fff;padding:16px;border:1px solid #e5e5e5;border-radius:8px;max-width:480px;">
  <form id="newsletter-block-form">
    <input
      type="email"
      name="email"
      placeholder="Email address"
      required
      style="width:100%;padding:10px;margin-bottom:8px;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;"
    />
    <input
      type="text"
      name="firstName"
      placeholder="First name"
      style="width:100%;padding:10px;margin-bottom:8px;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;"
    />
    <input
      type="text"
      name="lastName"
      placeholder="Last name"
      style="width:100%;padding:10px;margin-bottom:8px;border:1px solid #ccc;border-radius:4px;box-sizing:border-box;"
    />
    <button
      type="submit"
      id="newsletter-submit-btn"
      style="width:100%;padding:10px;border:none;border-radius:4px;background:#5c6ac4;color:#fff;font-weight:bold;cursor:pointer;"
    >
      Subscribe
    </button>
  </form>
  <p id="newsletter-status" style="margin-top:8px;font-size:0.95rem;"></p>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const form = document.getElementById('newsletter-block-form');
  const status = document.getElementById('newsletter-status');
  const btn = document.getElementById('newsletter-submit-btn');

  if (!form) return;

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    const email = (form.querySelector('[name="email"]').value || '').trim();
    const firstName = (form.querySelector('[name="firstName"]').value || '').trim();
    const lastName = (form.querySelector('[name="lastName"]').value || '').trim();

    if (!email) {
      status.style.color = '#cc0000';
      status.textContent = 'Please enter a valid email address.';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Submitting...';
    status.textContent = '';

    try {
      const res = await fetch('/apps/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          firstName,
          lastName,
          shop: '{{ shop.domain }}',
        }),
      });

      let data;
      try {
        data = await res.json();
      } catch {
        throw new Error('Invalid response from server');
      }

      if (data.status === 'subscribed') {
        form.style.display = 'none';
        status.style.color = '#008060';
        status.textContent = data.message || 'You have been subscribed successfully, thank you!';
      } else if (data.status === 'already_subscribed') {
        form.style.display = 'none';
        status.style.color = '#888';
        status.textContent = data.message || "You've already subscribed, thank you!";
      } else {
        status.style.color = '#cc0000';
        status.textContent = data.message || 'Something went wrong, please try again.';
        btn.disabled = false;
        btn.textContent = 'Subscribe';
      }
    } catch (err) {
      console.error('Subscribe error:', err);
      status.style.color = '#cc0000';
      status.textContent = 'Network error, please try again.';
      btn.disabled = false;
      btn.textContent = 'Subscribe';
    }
  });
});
</script>

{% schema %}
{
  "name": "Newsletter signup",
  "target": "section",
  "settings": []
}
{% endschema %}